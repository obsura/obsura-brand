{
  "brand": "Obsura",
  "repository": "obsura-brand",
  "role": "canonical-brand-repository",
  "status": "provisional",
  "description": "Source-of-truth brand assets, reference design inputs, and asset metadata for Obsura.",
  "statusModel": [
    "draft",
    "provisional",
    "approved",
    "deprecated"
  ],
  "sourceFormats": {
    "preferredEditable": "svg",
    "approvedRuntimeExport": "png"
  },
  "themeCompatibility": {
    "dark": "Use assets designed for dark surfaces or controlled-background exports.",
    "light": "Use assets designed for light surfaces or transparent exports with sufficient contrast."
  },
  "directories": {
    "logo/svg": {
      "purpose": "Canonical SVG logo and mark files.",
      "status": "draft"
    },
    "logo/png": {
      "purpose": "Approved PNG exports of official logos and marks.",
      "status": "draft"
    },
    "icons/monochrome/black": {
      "purpose": "Current transparent black icon exports.",
      "status": "approved"
    },
    "icons/favicon": {
      "purpose": "Reserved for curated favicon bundles if added later.",
      "status": "draft"
    },
    "icons/app": {
      "purpose": "Reserved for curated app icon packages if added later.",
      "status": "draft"
    },
    "icons/social": {
      "purpose": "Reserved for platform-specific social icon exports.",
      "status": "draft"
    },
    "previews/github": {
      "purpose": "GitHub avatar and social preview assets.",
      "status": "draft"
    },
    "previews/product": {
      "purpose": "Product-adjacent preview assets.",
      "status": "draft"
    },
    "previews/website": {
      "purpose": "Website-specific preview assets.",
      "status": "draft"
    },
    "samples_ui_ux": {
